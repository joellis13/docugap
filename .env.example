# DocuGap — Environment Variables
#
# Copy this file to .env and fill in your values.
# Never commit the .env file — it is listed in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Anthropic (required when docugap.llm.provider=anthropic — the default)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Azure AI Foundry (required when docugap.llm.provider=azure)
# ---------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_DEPLOYMENT_NAME=gpt-4o

# ---------------------------------------------------------------------------
# GitHub (required)
# ---------------------------------------------------------------------------
# Repository to analyze in owner/repo format.
GITHUB_DEFAULT_REPO=your-org/your-repo

